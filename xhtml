    <script>
        // --- DATA & STATE ---
        const state = {
            balance: 1250,
            completedTasks: 12,
            role: 'user', // 'user' or 'admin'
            currentTaskId: null,
            tasks: [
                { id: 1, title: 'Telegram Channel জয়েন করুন', reward: 500, type: 'Join', link: '#' },
                { id: 2, title: 'YouTube ভিডিওতে লাইক ও কমেন্ট', reward: 300, type: 'Social', link: '#' },
                { id: 3, title: 'Facebook পেজ ফলো করুন', reward: 200, type: 'Follow', link: '#' },
                { id: 4, title: 'ওয়েবসাইটে ভিজিট করুন (৩০ সেকেন্ড)', reward: 150, type: 'Visit', link: '#' }
            ],
            submissionQueue: [
                { id: 101, userId: 'User_A', taskName: 'Telegram Channel জয়েন করুন', proof: 'https://prnt.sc/xyz123', ip: '103.22.0.1' },
                { id: 102, userId: 'FakeUser_X', taskName: 'YouTube ভিডিওতে লাইক', proof: 'clicked_botted', ip: '10.0.0.5 (VPN)' }
            ],
            withdrawalRequests: [
                { id: 501, user: 'Rakib', method: 'bkash', account: '01700000000', points: 5000, status: 'Pending' },
                { id: 502, user: 'Sara', method: 'crypto', account: 'T9x...zL2', points: 10000, status: 'Paid' }
            ],
            userHistory: [
                { date: '2023-10-01', method: 'bkash', points: 5000, status: 'Paid' }
            ]
        };

        // --- DOM ELEMENTS ---
        const els = {
            balance: document.getElementById('user-balance'),
            completed: document.getElementById('completed-tasks'),
            taskList: document.getElementById('task-list-container'),
            queueList: document.getElementById('admin-task-queue'),
            pendingCount: document.getElementById('pending-count'),
            noPending: document.getElementById('no-pending-tasks'),
            payList: document.getElementById('admin-payment-list'),
            withdrawHistory: document.getElementById('withdraw-history-body'),
            modal: document.getElementById('taskModal'),
            modalTitle: document.getElementById('modal-task-title'),
            proofInput: document.getElementById('task-proof'),
            toast: document.getElementById('toast'),
            sidebar: document.getElementById('sidebar'),
            adminLinks: document.querySelectorAll('.admin-only')
        };

        // --- INIT ---
        function init() {
            updateUserStats();
            renderTasks();
            renderAdminQueue();
            renderAdminPayments();
            renderWithdrawHistory();
        }

        // --- CORE FUNCTIONS ---

        function updateUserStats() {
            els.balance.textContent = state.balance;
            els.completed.textContent = state.completedTasks;
        }

        function setRole(role) {
            state.role = role;
            
            // Update Buttons
            document.getElementById('btn-user-mode').classList.toggle('active', role === 'user');
            document.getElementById('btn-admin-mode').classList.toggle('active', role === 'admin');

            // Toggle Admin Links in Sidebar
            els.adminLinks.forEach(el => {
                el.style.display = role === 'admin' ? 'block' : 'none';
            });

            // Redirect based on role
            if (role === 'admin') {
                switchTab('admin-queue');
            } else {
                switchTab('dashboard');
            }

            showToast(`${role === 'admin' ? 'অ্যাডমিন' : 'ইউজার'} মোডে সুইচ করা হয়েছে`);
        }

        function switchTab(tabId) {
            // Hide all sections
            document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
            // Show target
            document.getElementById(tabId).classList.add('active');
            
            // Update Sidebar Active State
            document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
            // Find the link that calls this tab (simple heuristic)
            const activeLink = Array.from(document.querySelectorAll('.nav-link')).find(l => l.getAttribute('onclick').includes(tabId));
            if(activeLink) activeLink.classList.add('active');

            // Update Page Title
            const titles = {
                'dashboard': 'ড্যাশবোর্ড',
                'tasks': 'টাস্ক তালিকা',
                'wallet': 'ওয়ালেট',
                'admin-queue': 'অ্যাডমিন - টাস্ক রিভিউ',
                'admin-payments': 'অ্যাডমিন - পেমেন্ট'
            };
            document.getElementById('page-title').textContent = titles[tabId] || 'ড্যাশবোর্ড';

            // Mobile: Close sidebar after click
            if(window.innerWidth <= 768) {
                els.sidebar.classList.remove('active');
            }
        }

        // --- USER FEATURES ---

        function renderTasks() {
            els.taskList.innerHTML = '';
            state.tasks.forEach(task => {
                const div = document.createElement('div');
                div.className = 'task-item';
                div.innerHTML = `
                    <div class="task-info">
                        <h4>${task.title}</h4>
                        <span class="task-reward">+${task.reward} Pts</span>
                    </div>
                    <button class="btn btn-sm btn-primary" onclick="openTaskModal(${task.id})">শুরু করুন</button>
                `;
                els.taskList.appendChild(div);
            });
        }

        function openTaskModal(id) {
            const task = state.tasks.find(t => t.id === id);
            if (!task) return;
            state.currentTaskId = id;
            els.modalTitle.textContent = task.title + ' সাবমিট';
            els.proofInput.value = '';
            els.modal.classList.add('open');
        }

        function closeModal() {
            els.modal.classList.remove('open');
        }

        function submitTaskProof() {
            const proof = els.proofInput.value.trim();
            if (!proof) {
                showToast('দয়া করে প্রুফ দিন!', 'error');
                return;
            }

            // Add to Admin Queue
            const task = state.tasks.find(t => t.id === state.currentTaskId);
            state.submissionQueue.unshift({
                id: Date.now(),
                userId: 'User Demo',
                taskName: task.title,
                proof: proof,
                ip: '192.168.1.15'
            });

            closeModal();
            showToast('টাস্ক সফলভাবে জমা হয়েছে! রিভিউ এর জন্য অপেক্ষা করুন।');
            
            // Refresh Admin View just in case
            renderAdminQueue();
        }

        function handleWithdraw(e) {
            e.preventDefault();
            const amount = parseInt(document.getElementById('withdraw-amount').value);
            const method = document.getElementById('payment-method').value;
            const account = document.getElementById('withdraw-account').value;

            if (amount > state.balance) {
                showToast('পর্যাপ্ত ব্যালেন্স নেই!', 'error');
                return;
            }

            // Deduct balance temporarily (held)
            state.balance -= amount;
            updateUserStats();

            // Add to Admin Payment Request
            state.withdrawalRequests.unshift({
                id: Date.now(),
                user: 'User Demo',
                method: method,
                account: account,
                points: amount,
                status: 'Pending'
            });

            // Add to User History
            state.userHistory.unshift({
                date: new Date().toISOString().split('T')[0],
                method: method,
                points: amount,
                status: 'Pending'
            });

            e.target.reset();
            renderWithdrawHistory();
            renderAdminPayments();
            showToast('উইথড্র রিকোয়েস্ট পাঠানো হয়েছে।');
        }

        function renderWithdrawHistory() {
            els.withdrawHistory.innerHTML = state.userHistory.map(h => `
                <tr>
                    <td>${h.date}</td>
                    <td>${h.method.toUpperCase()}</td>
                    <td>${h.points}</td>
                    <td><span class="status-badge status-${h.status.toLowerCase()}">${h.status}</span></td>
                </tr>
            `).join('');
        }

        // --- ADMIN FEATURES ---

        function renderAdminQueue() {
            const pending = state.submissionQueue; // In real app, filter by status Pending
            els.pendingCount.textContent = pending.length;

            if (pending.length === 0) {
                els.queueList.innerHTML = '';
                els.noPending.style.display = 'block';
                return;
            }

            els.noPending.style.display = 'none';
            els.queueList.innerHTML = pending.map(sub => `
                <tr>
                    <td>${sub.userId}</td>
                    <td>${sub.taskName}</td>
                    <td>
                        <a href="#" style="color:var(--primary)" onclick="viewProof('${sub.proof}')">View Proof</a>
                    </td>
                    <td style="font-size: 11px; color: var(--text-muted);">${sub.ip}</td>
                    <td>
                        <button class="btn btn-sm btn-success" onclick="approveTask(${sub.id})"><i class="fas fa-check"></i></button>
                        <button class="btn btn-sm btn-danger" onclick="rejectTask(${sub.id})"><i class="fas fa-times"></i></button>
                    </td>
                </tr>
            `).join('');
        }

        function approveTask(id) {
            const index = state.submissionQueue.findIndex(s => s.id === id);
            if (index > -1) {
                const sub = state.submissionQueue[index];
                // Find task reward
                const task = state.tasks.find(t => t.title === sub.taskName);
                
                if (task) {
                    state.balance += task.reward;
                    state.completedTasks += 1;
                    updateUserStats();
                }

                state.submissionQueue.splice(index, 1);
                renderAdminQueue();
                showToast('টাস্ক অ্যাপ্রুভ করা হয়েছে এবং পয়েন্ট যোগ করা হয়েছে।');
            }
        }

        function rejectTask(id) {
            const index = state.submissionQueue.findIndex(s => s.id === id);
            if (index > -1) {
                state.submissionQueue.splice(index, 1);
                renderAdminQueue();
                showToast('টাস্ক রিজেক্ট করা হয়েছে।', 'error');
            }
        }

        function renderAdminPayments() {
            els.payList.innerHTML = state.withdrawalRequests.map(req => `
                <tr>
                    <td>${req.user}</td>
                    <td>${req.method.toUpperCase()}</td>
                    <td>${req.account}</td>
                    <td>${req.points}</td>
                    <td><span class="status-badge status-${req.status.toLowerCase()}">${req.status}</span></td>
                    <td>
                        ${req.status === 'Pending' ? `
                        <button class="btn btn-sm btn-success" onclick="payUser(${req.id})">Pay</button>
                        <button class="btn btn-sm btn-danger" onclick="deleteRequest(${req.id})">Del</button>
                        ` : '<span style="color:var(--text-muted)">-</span>'}
                    </td>
                </tr>
            `).join('');
        }

        function payUser(id) {
            const req = state.withdrawalRequests.find(r => r.id === id);
            if (req) {
                req.status = 'Paid';
                // Update user history UI as well if it matches current user
                const histItem = state.userHistory.find(h => h.points === req.points && h.status === 'Pending');
                if(histItem) histItem.status = 'Paid';
                
                renderAdminPayments();
                renderWithdrawHistory();
                showToast('পেমেন্ট স্ট্যাটাস Paid করা হয়েছে।');
            }
        }

        function deleteRequest(id) {
             const index = state.withdrawalRequests.findIndex(r => r.id === id);
             if(index > -1) {
                 const req = state.withdrawalRequests[index];
                 // Refund points to user balance (simulated)
                 state.balance += req.points;
                 updateUserStats();
                 
                 state.withdrawalRequests.splice(index, 1);
                 // Also remove from user history
                 state.userHistory = state.userHistory.filter(h => !(h.points === req.points && h.status === 'Pending'));

                 renderAdminPayments();
                 renderWithdrawHistory();
                 showToast('রিকোয়েস্ট বাতিল করা হয়েছে এবং পয়েন্ট ফেরত দেওয়া হয়েছে।');
             }
        }

        function viewProof(link) {
            // Simulate opening proof
            alert("প্রুফ ভিউ করা হচ্ছে: " + link + "\n(এটি একটি সিমুলেশন, বাস্তবে ছবি বা লিংক ওপেন হবে)");
        }

        // --- UTILS ---

        function showToast(msg, type = 'success') {
            els.toast.textContent = msg;
            els.toast.style.borderLeftColor = type === 'success' ? 'var(--success)' : 'var(--danger)';
            els.toast.classList.add('show');
            setTimeout(() => {
                els.toast.classList.remove('show');
            }, 3000);
        }

        function toggleSidebar() {
            els.sidebar.classList.toggle('active');
        }

        // Start
        init();

    </script>
</body>
</html>
